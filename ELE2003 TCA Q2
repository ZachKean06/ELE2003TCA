#include <LiquidCrystal.h>

#define RS     2
#define E      3
#define D4     4
#define D5     5
#define D6     6
#define D7     7

LiquidCrystal lcd(RS, E, D4, D5, D6, D7);

int EN1 = 10;
int IN1 = 9;
int IN2 = 8;
int potPin = A5;


void setup() {
  
	pinMode(EN1, OUTPUT);
  	pinMode(IN1, OUTPUT);
  	pinMode(IN2, OUTPUT);

  	digitalWrite(IN1, HIGH);
  	digitalWrite(IN2, LOW);
  
  	lcd.begin(16, 2);
	lcd.clear();

  	Serial.begin(9600);
  
}

void loop() {

  	int potValue = analogRead(potPin);
  	int speed = map(potValue, 0, 1023, 0, 255);
    int rpm = map(potValue, 0, 1023, 0, 9393);

  	analogWrite(EN1, speed);
  
  	lcd.clear();
	lcd.setCursor(0, 0);
	lcd.print("Speed: ");
    lcd.print(rpm);
    lcd.print("rpm");

  	Serial.print("Speed: ");
  	Serial.println(speed);
  	Serial.print("Rpm: ");
  	Serial.println(rpm);

  delay(100);
}
