#include <LiquidCrystal.h>

#define RS     2
#define E      3
#define D4     4
#define D5     5
#define D6     6
#define D7     7

LiquidCrystal lcd(RS, E, D4, D5, D6, D7);

int voltagePin = A5;

float R = 1000.0;

void setup() {
  lcd.begin(16, 2);
  Serial.begin(9600);
}

void loop() {

  int raw = analogRead(voltagePin);

  float voltage = raw * (5.0/1023);
  float current = voltage / R;
  float current_mA = current * 1000;

  lcd.setCursor(0, 0);
  lcd.print("V: ");
  lcd.print(voltage, 2);
  lcd.print(" V   ");

  lcd.setCursor(0, 1);
  lcd.print("I: ");
  lcd.print(current_mA, 1);
  lcd.print(" mA  ");

  Serial.print("Voltage: ");
  Serial.print(voltage);
  Serial.print(" V      Current: ");
  Serial.print(current_mA);
  Serial.println(" mA");

  delay(500);
}
